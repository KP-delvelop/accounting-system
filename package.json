{
  "name": "accounting-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "local-api": "node scripts/local-api.mjs",
    "check:readiness": "node scripts/readiness-check.mjs",
    "test:encoding": "node scripts/encoding-guard-test.mjs",
    "test:attachments": "node scripts/attachment-storage-dir-test.mjs",
    "test:golden": "node scripts/golden-output-parity-test.mjs",
    "test:supabase": "node scripts/supabase-hosted-smoke-test.mjs",
    "supabase:seed-demo": "node scripts/supabase-seed-demo.mjs",
    "test:lifecycle": "node scripts/document-lifecycle-numbering-test.mjs",
    "test:api": "node scripts/api-smoke-test.mjs",
    "test:ui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ui-smoke-test.ps1",
