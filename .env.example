# Phase 1 runs on localhost with browser-local persistence only.
VITE_DATA_MODE=local

# Local API auth boundary. Use `dev` only for local development and smoke tests.
# For production-like local readiness, set `required` and provide non-empty tokens.
LOCAL_API_AUTH_MODE=dev
LOCAL_API_AUTH_TOKEN=
LOCAL_API_ADMIN_TOKEN=
LOCAL_API_ACTOR_ID=local-api-owner
LOCAL_API_ROLE_KEY=owner
LOCAL_API_PERMISSIONS=
LOCAL_API_PORT=8787

# Local attachment storage for Phase 10A backend/API uploads.
LOCAL_ATTACHMENT_STORAGE_DIR=data/attachments
LOCAL_ATTACHMENT_MAX_BYTES=5000000
LOCAL_ATTACHMENT_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.txt,.csv,.xlsx,.docx

# Optional readiness-check overrides.
READINESS_API_BASE_URL=http://127.0.0.1:8787
READINESS_APP_URL=http://127.0.0.1:5173/
READINESS_EXPECT_AUTH_MODE=
READINESS_ADMIN_TOKEN=

# Reserved for a future hosted database adapter when the project moves to Hostinger.
VITE_REMOTE_DATABASE_URL=
